---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import Container from "@/components/Container.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import FormContact from "@/components/forms/FormContact.astro";
import FormEnrollment from "@/components/forms/FormEnrollment.astro";
import { phone, email, address } from "@/data/config";
---

<Layout title="Contact Us - Elementary">
	<Section>
		<Container>
			<SectionHeading>
				<h1 class="text-4xl font-bold tracking-wide font-fredoka">Contact &amp; Enrollment 📝</h1>
				<p>Have questions or ready to enroll? We'd love to hear from you!</p>
			</SectionHeading>

			<div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
				<!-- Sidebar -->
				<div class="lg:col-span-2 flex flex-col gap-6 lg:justify-between">
					<!-- Get In Touch -->
					<div class="rounded-2xl grow bg-white border border-gray-200 p-6 flex flex-col gap-4">
						<h2 class="font-fredoka text-xl font-semibold">Get In Touch</h2>
						<div class="flex items-start gap-3">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="size-5 text-brand-blue mt-0.5 shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
								></path>
							</svg>
							<span class="text-sm text-gray-500">
								{address.street}, {address.city}, {address.state}
								{address.zip}
							</span>
						</div>
						<div class="flex items-start gap-3">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="size-5 text-brand-blue mt-0.5 shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
								></path>
							</svg>
							<a href={phone.href} class="text-sm text-gray-500 hover:text-brand-blue transition">
								{phone.label}
							</a>
						</div>
						<div class="flex items-start gap-3">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="size-5 text-brand-blue mt-0.5 shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
								></path>
							</svg>
							<a href={email.href} class="text-sm text-gray-500 hover:text-brand-blue transition">
								{email.label}
							</a>
						</div>
						<div class="flex items-start gap-3">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="size-5 text-brand-blue mt-0.5 shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
							</svg>
							<span class="text-sm text-gray-500">Mon–Fri: 7:30 AM – 4:30 PM</span>
						</div>
					</div>

					<!-- Enrollment Info -->
					<div class="rounded-2xl grow border border-gray-200 bg-brand-blue/5 p-6 flex flex-col gap-4">
						<div class="flex items-center gap-3">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="size-6 text-brand-blue shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
								></path>
							</svg>
							<h3 class="font-fredoka text-lg font-semibold">Enrollment Info</h3>
						</div>
						<ul class="text-sm text-gray-500 flex flex-col gap-2 list-disc list-inside">
							<li>Open enrollment: March 1 – May 31</li>
							<li>Ages: 5–11 (Grades K–5)</li>
							<li>Required docs: birth certificate, immunization records, proof of residency</li>
							<li>Tour available by appointment</li>
						</ul>
					</div>
				</div>

				<!-- Form -->
				<div class="lg:col-span-3">
					<div class="bg-white rounded-2xl border border-gray-200 p-6 flex flex-col gap-6">
						<!-- Tabs -->
						<div class="flex flex-col gap-2">
							<div class="flex gap-2">
								<button
									data-tab-btn="contact"
									class="inline-flex items-center cursor-pointer font-bold rounded-2xl whitespace-nowrap transition px-3 py-2 text-base bg-brand-blue text-white hover:bg-brand-blue-dark"
									>Contact Us</button
								>
								<button
									data-tab-btn="enrollment"
									class="inline-flex items-center cursor-pointer font-bold rounded-2xl whitespace-nowrap transition px-3 py-2 text-base border border-gray-300 text-gray-800 hover:bg-gray-100"
									>Enrollment</button
								>
							</div>
							<h2 data-tab-title class="font-fredoka text-xl mt-4 font-semibold">Send Us a Message</h2>
						</div>

						<!-- Panels -->
						<div data-tab-panel="contact">
							<FormContact />
						</div>
						<div data-tab-panel="enrollment" hidden>
							<FormEnrollment />
						</div>
					</div>
				</div>
			</div>
		</Container>
	</Section>
</Layout>

<script>
	const btns = document.querySelectorAll("[data-tab-btn]") as NodeListOf<HTMLButtonElement>;
	const panels = document.querySelectorAll("[data-tab-panel]") as NodeListOf<HTMLElement>;
	const title = document.querySelector("[data-tab-title]") as HTMLElement | null;

	const titles: Record<string, string> = {
		contact: "Send Us a Message",
		enrollment: "Enrollment Request",
	};

	const activeClasses = ["bg-brand-blue", "text-white", "hover:bg-brand-blue-dark"];
	const inactiveClasses = ["border", "border-gray-300", "text-gray-800", "hover:bg-gray-100"];

	function activate(tab: string) {
		btns.forEach((btn) => {
			const isActive = btn.dataset.tabBtn === tab;
			if (isActive) {
				btn.classList.remove(...inactiveClasses);
				btn.classList.add(...activeClasses);
			} else {
				btn.classList.remove(...activeClasses);
				btn.classList.add(...inactiveClasses);
			}
		});

		panels.forEach((panel) => {
			panel.hidden = panel.dataset.tabPanel !== tab;
		});

		if (title) title.textContent = titles[tab] ?? "";
	}

	btns.forEach((btn) => btn.addEventListener("click", () => activate(btn.dataset.tabBtn!)));
</script>
