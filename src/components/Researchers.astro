---
import LucideMail from "~icons/lucide/mail";
import { Image } from "astro:assets";
import { researchers } from "@/data/researchers";
const base = import.meta.env.BASE_URL;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
	{
		researchers.map((person) => (
			<div class="bg-white rounded-2xl shadow hover:shadow-lg transition overflow-hidden">

				<!-- Image -->
				<div class="h-56 w-full overflow-hidden">
					<Image
						src={`/${person.image.replace(/^\//, "")}`}
						alt={person.name}
						width={400}
						height={300}
						class="w-full h-full object-cover"
					/>
				</div>

				<!-- Content -->
				<div class="p-6 flex flex-col">
					<h3 class="font-fredoka text-xl text-brand-foreground mb-1">
						{person.name}
					</h3>

					<span class="font-nunito font-bold text-sm text-brand-blue mb-3">
						{person.role}
					</span>

					<p class="font-nunito text-sm text-brand-foreground/70 mb-4">
						{person.bio}
					</p>

					<a
						href={`mailto:${person.email}`}
						class="mt-auto inline-flex items-center gap-2 text-sm font-nunito font-bold text-brand-blue hover:underline"
					>
						<LucideMail class="w-4 h-4" />
						{person.email}
					</a>
				</div>
			</div>
		))
	}
</div>