---
import { getCollection } from "astro:content";
import { categoryBgColor, categoryLabel, formatDate } from "@/utils/blogUtils";
import LucideCalendar from "~icons/lucide/calendar";

const allPosts = await getCollection("blog");

const posts = allPosts.sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = [...new Set(posts.map((p) => p.data.category))].sort();
const base = import.meta.env.BASE_URL;

---

<div class="max-w-4xl mx-auto">
	<!-- Filters -->
	<div class="flex flex-wrap gap-2 mb-10 justify-center">
		<button
			class="filter-btn bg-brand-blue text-white border-brand-blue px-4 py-1.5 rounded-full text-sm font-medium border transition cursor-pointer"
			data-filter="all"
		>
			All
		</button>

		{
			categories.map((cat) => (
				<button
					class="filter-btn bg-white text-brand-foreground border-brand-foreground/20 hover:border-brand-foreground px-4 py-1.5 rounded-full text-sm font-medium border transition cursor-pointer"
					data-filter={cat}
				>
					{categoryLabel(cat)}
				</button>
			))
		}
	</div>

	<!-- News list -->
	<div class="flex flex-col gap-6">
		{
			posts.map((post) => {
				const href = `${base}/news/${post.id}`;

				return (
					<div class="blog-item" data-category={post.data.category}>
						<article class="group bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition relative">

							{/* Top row */}
							<div class="flex items-center gap-3 mb-2 flex-wrap">
								<span
									class={`text-xs font-semibold rounded-full px-2 py-1 ${categoryBgColor(
										post.data.category
									)} text-white`}
								>
									{categoryLabel(post.data.category)}
								</span>

								<span class="text-sm text-brand-foreground/50 flex items-center">
									<LucideCalendar class="inline-block size-4 mr-1" />
									{formatDate(post.data.pubDate)}
								</span>
							</div>

							{/* Title */}
							<h2 class="text-xl font-semibold mb-2 leading-snug">
								{post.data.title}
							</h2>

							{/* Excerpt */}
							<p class="text-base text-brand-foreground/70 mb-4 leading-relaxed">
								{post.data.excerpt}
							</p>

							{/* Link (ALWAYS internal now) */}
							<a
								href={href}
								class="text-brand-blue text-sm font-bold"
							>
								Read more →
								<span class="absolute inset-0" />
							</a>
						</article>
					</div>
				);
			})
		}
	</div>
</div>

<script>
	const buttons = document.querySelectorAll("[data-filter]");
	const items = document.querySelectorAll(".blog-item");

	const activeClasses = ["bg-brand-blue", "text-white", "border-brand-blue"];
	const inactiveClasses = [
		"bg-white",
		"text-brand-foreground",
		"border-brand-foreground/20",
		"hover:border-brand-foreground",
	];

	buttons.forEach((btn) => {
		btn.addEventListener("click", () => {
			const filter = btn.dataset.filter ?? "all";

			buttons.forEach((b) => {
				b.classList.remove(...activeClasses);
				b.classList.add(...inactiveClasses);
			});

			btn.classList.remove(...inactiveClasses);
			btn.classList.add(...activeClasses);

			items.forEach((item) => {
				const match =
					filter === "all" || item.dataset.category === filter;
				item.classList.toggle("hidden", !match);
			});
		});
	});
</script>