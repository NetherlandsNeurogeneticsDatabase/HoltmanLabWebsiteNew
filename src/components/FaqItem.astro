---
import type { FaqItemProps as Props } from "@/types";
const { id, question, answer, open = false } = Astro.props;
---

<div class="border border-brand-foreground/15 rounded-2xl overflow-hidden">
	<dt>
		<button
			type="button"
			command="--toggle"
			commandfor={id}
			aria-expanded={open ? "true" : undefined}
			class="w-full cursor-pointer flex items-center justify-between p-5 text-left text-brand-foreground hover:bg-brand-foreground/5 transition-colors"
		>
			<span class="font-bold pr-4">{question}</span>
			<span class="ml-6 flex h-7 items-center shrink-0">
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
					class="size-5 text-gray-500 in-aria-expanded:hidden"
				>
					<path d="M12 6v12m6-6H6" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
					class="size-5 text-gray-500 not-in-aria-expanded:hidden"
				>
					<path d="M18 12H6" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</span>
		</button>
	</dt>
	<el-disclosure id={id} hidden={!open || undefined} class="contents">
		<dd class="px-5 pb-5 pt-1">
			{answer}
		</dd>
	</el-disclosure>
</div>
