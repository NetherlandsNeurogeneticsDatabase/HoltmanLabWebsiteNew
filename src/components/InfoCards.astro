---
import LucideBell from '~icons/lucide/bell'
import LucideCalendarDays from '~icons/lucide/calendar-days'
import LucideBookOpen from '~icons/lucide/book-open'
import LucideUtensils from '~icons/lucide/utensils'

const base = import.meta.env.BASE_URL;

const cards = [
	{
		title: "Brain bank staff visit!",
		description:
			"The Netherlands Brain Bank staff visited 'Bodies the exhibition' in Amsterdam - purely profesional curiosity of course.",
		color: "bg-taupe-500 text-white",
		image: `/images/brainbankvisit.png`,
		link: `/news`,
	},
	{
		title: "New paper on MS",
		description:
			"We are excited to share a new publication in collaboration with Karim Kreft from the University of Nottingham on...",
		color: "bg-taupe-500 text-white",
		image: `/images/nature_genetics.jpg`,
		link: `/news`,
	},
	{
		title: "New NND website",
		description:
			"The Netherlands Neurogenomics Database (NND) has launched a new website.\n\n",
		color: "bg-taupe-500 text-white",
		image: `/images/NND_logo_orange.png`,
		link: `/news`,
	},
	{
		title: "iCNS kickoff",
		description:
			"Kickoff event in Amsterdam launching the iCNS research program.\n\n",
		color: "bg-taupe-500 text-white",
		image: `/images/i-CNS.jpg`,
		link: `/news`,
	},
];
---

<div class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
	{
		cards.map(({ title, description, color, image, link }) => (
			<a
				href={link}
				class="group rounded-lg overflow-hidden shadow hover:shadow-lg transition bg-white"
			>
				<!-- Image -->
				<div class="h-40 overflow-hidden">
					<img
						src={image}
						alt={title}
						class="w-full h-full object-cover group-hover:scale-105 transition"
					/>
				</div>

				<!-- Content -->
				<div class={`p-5 ${color}`}>
					<h3 class="text-xl font-bold mb-2">{title}</h3>

					<p class="text-sm font-medium opacity-90 whitespace-pre-line">
						{description}
					</p>

					<div class="mt-4 text-sm underline opacity-90 group-hover:opacity-100">
						Read more →
					</div>
				</div>
			</a>
		))
	}
</div>